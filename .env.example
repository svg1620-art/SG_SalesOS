# Пример переменных окружения для SG_SalesOS.
# На Railway задавать ПО ОДНОЙ через «New Variable», БЕЗ кавычек.
# Локально: скопировать в .env (dotenv подхватит), для Railway — в Variables.

# --- Обязательные для Этапа 1 ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SECRET_KEY=

# Сид админа (для команды seed-admin)
ADMIN_EMAIL=admin@service.guru
ADMIN_PASSWORD=
ADMIN_NAME=Администратор
# true → админ создаётся автоматически при старте (если нет доступа к консоли).
# После первого успешного старта переменную убрать.
SEED_ADMIN_ON_START=false

# Таймзона
TZ=Europe/Moscow

# --- Хранилище аудио (Volume, пригодится с Этапа 3) ---
AUDIO_DIR=/data

# --- ИИ (нужны с Этапа 3, модели НЕ хардкодим) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=
CLAUDE_MODEL_DIGEST=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# --- Фон/расписание (Этапы 8-9) ---
# true → запускать APScheduler (дневная сводка + Telegram-пульс)
SCHEDULER_ENABLED=false
POLL_INTERVAL_MIN=15
DIGEST_HOUR=20
TELEGRAM_HOUR=19

# --- Telegram-пульс (дневной отчёт по менеджерам) ---
TELEGRAM_BOT_TOKEN=
# chat_id получателей через запятую (РОП, владелец)
TELEGRAM_CHAT_IDS=

# --- amoCRM (Этап 8) ---
# Можно задать здесь или в UI «Настройки». Долгосрочный токен — простейший путь.
AMO_BASE_DOMAIN=serviceguru.amocrm.ru
AMO_ACCESS_TOKEN=
AMO_ENTITY=contacts
# OAuth (запасной путь, если не использовать долгосрочный токен)
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=
AMO_AUTH_CODE=
